# Copy to .env for local live testing (.env is gitignored). The binary does NOT
# load this file — source it in your shell: `set -a; . ./.env; set +a`.
# Reads and explicit `cred remember` need no key; only `cred curate` (the
# automatic write path) calls the model.

# Provider is chosen by CRED_LLM_BASE_URL:
#   unset            -> Anthropic (Claude). CRED_LLM_MODEL defaults.
#   an endpoint URL  -> OpenAI-compatible: OpenAI, DeepSeek, or self-hosted
#                       (vLLM, Ollama, LM Studio). CRED_LLM_MODEL is required.
export CRED_LLM_API_KEY=""

# --- Claude (leave BASE_URL unset) ---
# export CRED_LLM_MODEL="claude-opus-4-8"

# --- DeepSeek ---
# export CRED_LLM_BASE_URL="https://api.deepseek.com"
# export CRED_LLM_MODEL="deepseek-chat"

# --- OpenAI ---
# export CRED_LLM_BASE_URL="https://api.openai.com/v1"
# export CRED_LLM_MODEL="gpt-4o"

# --- Self-hosted (Ollama example) ---
# export CRED_LLM_BASE_URL="http://localhost:11434/v1"
# export CRED_LLM_MODEL="llama3.1"
